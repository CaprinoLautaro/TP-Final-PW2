<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Revisar preguntas</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./public/css/habilitarPreguntaView.css">
</head>

<body>

{{> header}}

<main>

    <div class="welcome-card">
        <h1>
            <span>Moderación</span>
            Editar preguntas
        </h1>
    </div>

    <!-- ── EDITAR PREGUNTAS ── -->
    <div class="section-title">
        Editar Preguntas
    </div>

    <div class="partidas-list">

        {{#preguntas}}
            <div class="partida-card">

                <div class="partida-info">
                    <div class="detalle">{{enunciado}}</div>
                    <div class="fecha">Categoría: {{categoria}}</div>
                </div>

                <div class="partida-resultado">
                                        <a href="?controller=pregunta&method=editarPregunta&id={{id}}"
                    class="btn-editar">
                    ✏️ Editar
                    </a>
                </div>

            </div>
        {{/preguntas}}

        {{^preguntas}}
            <div class="empty">
                <strong>No hay preguntas pendientes</strong>
                <p>Todas las preguntas ya fueron revisadas.</p>
            </div>
        {{/preguntas}}

    </div>

    <div class="actions">
        <a href="?controller=home&method=index" class="btn-main btn-ranking btn-volver">
            ⬅ Volver al inicio
        </a>
    </div>

</main>

{{> footer}}

</body>
</html>