<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Registro</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./public/css/registroView.css">
    <link rel="stylesheet" href="./public/css/homeView.css">
</head>
<body>

{{>header}}

<main>
    <h2 class="section-title">Crear nueva cuenta</h2>

    <form class="register-form" action="?controller=user&method=procesarRegistroUsuario" method="POST" enctype="multipart/form-data">

        <div class="form-section">
            <h3>Datos Personales</h3>

            <div class="input-group">
                <label for="nombre">Nombre Completo</label>
                <input type="text" id="nombre" name="nombre-completo" placeholder="Ej. Juan Pérez" required>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="nacimiento">Año de Nacimiento</label>
                    <input type="number" id="nacimiento" name="anio-nacimiento" min="1900" max="2026" placeholder="Ej. 1995" required>
                </div>

                <div class="input-group">
                    <label for="sexo">Sexo</label>
                    <select id="sexo" name="sexo" required>
                        <option value="" disabled selected>Seleccioná una opción</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="NoCargar">Prefiero no cargarlo</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3>Ubicación</h3>
            <p class="form-instruction">Hacé clic en el mapa para marcar tu ubicación:</p>

            <div class="map-container">
                <div id="map" style="width: 100%; height: 300px; border-radius: 8px;"></div>
            </div>

            <input type="hidden" id="latitud" name="latitud">
            <input type="hidden" id="longitud" name="longitud">

            <input type="hidden" id="pais_id" name="pais_id">
        </div>

        <div class="form-section">
            <h3>Perfil de Usuario</h3>

            <div class="input-group">
                <label for="username">Nombre de Usuario</label>
                <input type="text" id="username" name="user-name" placeholder="Ej. juan_capo12" required>
            </div>

            <div class="input-group">
                <label for="avatar">Foto de Perfil</label>
                <div class="file-upload-wrapper">
                    <input type="file" id="avatar" name="foto" required>
                    <div class="file-upload-btn">Seleccionar Imagen</div>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3>Credenciales</h3>

            <div class="input-group">
                <label for="email">Correo Electrónico</label>
                <input type="email" id="email" name="email" placeholder="ejemplo@correo.com" required>
                <span class="input-help">Te enviaremos un link de validación para activar tu cuenta.</span>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="contrasenia" placeholder="••••••••" required>
                </div>

                <div class="input-group">
                    <label for="password_repeat">Repetir Contraseña</label>
                    <input type="password" id="password_repeat" name="contrasenia" placeholder="••••••••" required>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-main btn-jugar btn-submit">
            Registrar
        </button>
    </form>
</main>

{{>footer}}

<script>
    let map;
    let marker;

    function initMap() {
        // Coordenadas por defecto (Buenos Aires) por si el usuario no comparte su GPS
        const defaultCoords = { lat: -34.6037, lng: -58.3816 };

        // Inyectar el mapa en el div con id "map"
        map = new google.maps.Map(document.getElementById("map"), {
            zoom: 12,
            center: defaultCoords,
        });

        // Intentar centrar el mapa automáticamente con el GPS del navegador
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition((position) => {
                const userPos = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                };
                map.setCenter(userPos);
            });
        }

        // Escuchar los clics del usuario en el mapa
        map.addListener("click", (mapsMouseEvent) => {
            const clickedPos = mapsMouseEvent.latLng;

            // Si ya existe un marcador, lo movemos. Si no, lo creamos.
            if (marker) {
                marker.setPosition(clickedPos);
            } else {
                marker = new google.maps.Marker({
                    position: clickedPos,
                    map: map,
                });
            }

            // Guardar la latitud y longitud exactas en tus inputs ocultos
            document.getElementById("latitud").value = clickedPos.lat();
            document.getElementById("longitud").value = clickedPos.lng();

            console.log(`Coordenadas guardadas: Lat ${clickedPos.lat()}, Lng ${clickedPos.lng()}`);
        });
    }
</script>

<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAcW2OczhYH2aFqMMF2VG-asLJf3HJJzxg&callback=initMap" async defer></script>
</body>
</html>