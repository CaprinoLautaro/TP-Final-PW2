<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Registro</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./public/css/registroView.css">
    <link rel="stylesheet" href="./public/css/homeView.css">
</head>
<body>

{{>header}}

<main>
    <h2 class="section-title">Crear nueva cuenta</h2>
    {{#error}}
        <div class="error-message">
            {{error}}
        </div>
    {{/error}}

    <form class="register-form" action="?controller=user&method=procesarRegistroUsuario" method="POST" enctype="multipart/form-data">

        <div class="form-section">
            <h3>Datos Personales</h3>

            <div class="input-group">
                <label for="nombre">Nombre Completo</label>
                <input type="text" id="nombre" name="nombre-completo" placeholder="Ej. Juan Pérez" required>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="nacimiento">Año de Nacimiento</label>
                    <input type="number" id="nacimiento" name="anio-nacimiento" min="1900" max="2026" placeholder="Ej. 1995" required>
                </div>

                <div class="input-group">
                    <label for="sexo">Sexo</label>
                    <select id="sexo" name="sexo" required>
                        <option value="" disabled selected>Seleccioná una opción</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Prefiero no cargarlo">
                            Prefiero no cargarlo
                        </option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3>Ubicación</h3>
            <p class="form-instruction">Hacé clic en el mapa para marcar tu ubicación:</p>

            <div class="map-container">
                <div id="map" style="width: 100%; height: 300px; border-radius: 8px;"></div>
            </div>
            <p id="ubicacion-status" class="input-help">
                Seleccioná una ubicación en el mapa
            </p>


            <input type="hidden" id="latitud" name="latitud">
            <input type="hidden" id="longitud" name="longitud">

            <div class="form-row">

                <div class="input-group">
                    <label for="pais_id">País</label>

                    <select id="pais_id"
                            name="pais_id"
                            required>

                        <option value="" disabled selected>
                            Seleccioná tu país
                        </option>

                        <option value="1">Argentina</option>
                        <option value="2">Uruguay</option>
                        <option value="3">Chile</option>
                        <option value="4">Brasil</option>
                        <option value="5">México</option>

                    </select>
                </div>

                <div class="input-group">
                    <label for="ciudad">Ciudad</label>

                    <input type="text"
                           id="ciudad"
                           name="ciudad"
                           placeholder="Ej. Buenos Aires"
                           required>
                </div>

            </div>
        </div>


        <div class="form-section">
            <h3>Perfil de Usuario</h3>

            <div class="input-group">
                <label for="username">Nombre de Usuario</label>
                <input type="text" id="username" name="user-name" placeholder="Ej. juan_capo12" required>
            </div>

            <div class="input-group">
                <label for="avatar">
                    Foto de Perfil
                </label>

                <div class="file-upload-wrapper">

                    <input
                            type="file"
                            id="avatar"
                            name="foto"
                            accept="image/*"
                            required
                    >

                    <div class="file-upload-btn">
                        Seleccionar Imagen
                    </div>
                </div>

                <!-- Preview -->
                <div class="preview-container">
                    <img
                            id="preview-imagen"
                            src="./public/img/default-user.png"
                            alt="Vista previa"
                    >
                </div>
            </div>

        <div class="form-section">
            <h3>Credenciales</h3>

            <div class="input-group">
                <label for="email">Correo Electrónico</label>
                <input type="email" id="email" name="email" placeholder="ejemplo@correo.com" required>
                <span class="input-help">Te enviaremos un link de validación para activar tu cuenta.</span>
            </div>

            <div class="form-row">

                <div class="input-group">
                    <label for="password">
                        Contraseña
                    </label>

                    <input
                            type="password"
                            id="password"
                            name="contrasenia"
                            placeholder="••••••••"
                            required
                    >
                </div>

                <div class="input-group">
                    <label for="password_repeat">
                        Repetir Contraseña
                    </label>

                    <input
                            type="password"
                            id="password_repeat"
                            name="repetir_contrasenia"
                            placeholder="••••••••"
                            required
                    >
                </div>

            </div>

        <button type="submit" class="btn-main btn-jugar btn-submit">
            Registrar
        </button>
    </form>
</main>

{{>footer}}

<script>
    let map;
    let marker;

    function initMap() {

        // Buenos Aires por defecto
        const defaultCoords = {
            lat: -34.6037,
            lng: -58.3816
        };

        map = new google.maps.Map(
                document.getElementById("map"),
                {
                    zoom: 12,
                    center: defaultCoords
                }
        );

        // Intentar usar GPS del navegador
        if (navigator.geolocation) {

            navigator.geolocation.getCurrentPosition(

                    (position) => {

                        const userPos = {
                            lat: position.coords.latitude,
                            lng: position.coords.longitude
                        };

                        map.setCenter(userPos);
                    },

                    () => {
                        console.log(
                                "No se pudo obtener la ubicación del navegador"
                        );
                    }
            );
        }

        // Click del usuario en el mapa
        map.addListener("click", (mapsMouseEvent) => {

            const clickedPos = mapsMouseEvent.latLng;

            // Crear o mover marcador
            if (marker) {

                marker.setPosition(clickedPos);

            } else {

                marker = new google.maps.Marker({
                    position: clickedPos,
                    map: map
                });
            }

            // Guardar coordenadas
            document.getElementById("latitud").value =
                    clickedPos.lat();

            document.getElementById("longitud").value =
                    clickedPos.lng();

            // Mostrar feedback visual
            const status =
                    document.getElementById(
                            "ubicacion-status"
                    );

            if (status) {
                status.innerText =
                        "Ubicación seleccionada correctamente";
            }

            console.log(
                    "Lat:",
                    clickedPos.lat(),
                    "Lng:",
                    clickedPos.lng()
            );
        });

        // Validación del formulario
        document.querySelector(
                ".register-form"
        ).addEventListener(
                "submit",
                function (e) {

                    const latitud =
                            document.getElementById(
                                    "latitud"
                            ).value;

                    const longitud =
                            document.getElementById(
                                    "longitud"
                            ).value;

                    const password =
                            document.getElementById(
                                    "password"
                            ).value;

                    const passwordRepeat =
                            document.getElementById(
                                    "password_repeat"
                            ).value;

                    if (!latitud || !longitud) {

                        e.preventDefault();

                        alert(
                                "Seleccioná una ubicación en el mapa."
                        );

                        return;
                    }

                    if (password !== passwordRepeat) {

                        e.preventDefault();

                        alert(
                                "Las contraseñas no coinciden."
                        );

                        return;
                    }
                }
        );
    }
</script>

<script>
    document
            .getElementById("avatar")
            .addEventListener(
                    "change",
                    function (event) {

                        const archivo =
                                event.target.files[0];

                        if (!archivo) return;

                        const reader =
                                new FileReader();

                        reader.onload =
                                function (e) {

                                    document
                                            .getElementById(
                                                    "preview-imagen"
                                            )
                                            .src =
                                            e.target.result;
                                };

                        reader.readAsDataURL(
                                archivo
                        );
                    }
            );
</script>

<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAcW2OczhYH2aFqMMF2VG-asLJf3HJJzxg&callback=initMap" async defer></script>
</body>
</html>