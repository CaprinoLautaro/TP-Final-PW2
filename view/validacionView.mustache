<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Validar Cuenta</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./public/css/homeView.css">
    <link rel="stylesheet" href="./public/css/registroView.css">
    <link rel="stylesheet" href="./public/css/validacionView.css">
</head>
<body>

{{>header}}

<main>
    <h1>Revisá tu correo</h1>
    <p>Te enviamos un código de validación por email.</p>

    <form action="?controller=user&method=validarToken" method="POST">
        <input
            type="text"
            name="token"
            placeholder="Ingresá tu código"
            required
        >
        <button type="submit">Validar cuenta</button>
    </form>
</main>

{{>footer}}

</body>
</html>