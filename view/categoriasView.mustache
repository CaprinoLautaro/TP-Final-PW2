<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Crear Pregunta</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap"
          rel="stylesheet">

    <link rel="stylesheet" href="./public/css/categoriasView.css">
</head>

<body>

{{> header}}

<main>

    <div class="categorias-header">

        <h1 class="section-title">
            🏷️ CATEGORÍAS
        </h1>

        <a href="?controller=categoria&method=crear"
           class="btn-main btn-nueva-categoria">
            + Nueva categoría
        </a>

    </div>

    <div class="categorias-lista">

        {{#categorias}}
            <div class="categoria-card">

                <div class="categoria-info">

                <span
                        class="categoria-color"
                        style="background-color: {{color}};">
                </span>

                    <div>
                        <div class="categoria-nombre">
                            {{nombre}}
                        </div>

                        <div class="categoria-estado">
                            {{#activa}}
                                ✅ Activa
                            {{/activa}}

                            {{^activa}}
                                ❌ Inactiva
                            {{/activa}}
                        </div>
                    </div>

                </div>

                <div class="categoria-acciones">

                    <div class="switch-container">

        <span class="switch-label">
            Activa
        </span>

                        <a href="?controller=categoria&method=toggle&id={{id}}"
                        class="switch-link">

                        <div class="switch {{#activa}}activo{{/activa}}">
                            <div class="switch-thumb"></div>
                        </div>

                        </a>

                    </div>

                    <a href="?controller=categoria&method=editar&id={{id}}"
                    class="btn-editar-categoria">
                    ✏️ Editar
                    </a>

                </div>

            </div>
        {{/categorias}}

        {{^categorias}}
            <div class="empty">
                <strong>No hay categorías creadas</strong>
            </div>
        {{/categorias}}

    </div>

</main>

{{> footer}}

</body>
</html>