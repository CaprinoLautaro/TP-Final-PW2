<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Lobby</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="./public/css/homeView.css">
</head>

<body>

{{> header}}

<main>

    <!-- Bienvenida + puntaje -->
    <div class="welcome-card">
        <h1>
            <span>Bienvenido de nuevo,</span>
            {{nombre_completo}}
        </h1>

        <div class="puntaje-badge">
            <div class="num">{{puntaje_total}}</div>
            <div class="label">Puntos totales</div>
        </div>
    </div>

    <!-- Trampitas -->
    <div class="trampitas-bar">
        <div class="info">
            <span class="icon">🃏</span>
            <span>
                Tenés <strong>{{trampitas}}</strong>
                trampita{{#trampitas_plural}}s{{/trampitas_plural}}
            </span>
        </div>

        <a href="?controller=trampitas&method=comprar" class="btn-comprar">
            + Comprar
        </a>
    </div>

    <!-- Botones principales -->
    <div class="actions">

        <!-- Fila superior: Ranking + Crear pregunta -->
        <div class="actions-secundarias">
            <a href="?controller=ranking&method=index" class="btn-main btn-ranking">
                🏆 Ver ranking
            </a>

            <a href="?controller=pregunta&method=crear" class="btn-main btn-crear">
                ✏️ Crear pregunta
            </a>
        </div>

        <!-- Fila inferior: Nueva partida -->
        <a href="?controller=partida&method=nueva" class="btn-main btn-jugar">
            ▶ Nueva partida
        </a>

    </div>

    <!-- Historial -->
    <div class="section-title">Mis partidas</div>

    <div class="partidas-list">

        {{#partidas}}
            <div class="partida-card {{resultado}}">
                <div class="partida-info">
                    <div class="fecha">{{fecha}}</div>
                    <div class="detalle">{{detalle}}</div>
                </div>

                <div class="partida-resultado">
                    <div class="ptos {{resultado}}">
                        {{puntaje}}
                    </div>

                    <div class="sub">puntos</div>
                </div>
            </div>
        {{/partidas}}

        {{^partidas}}
            <div class="empty">
                <strong>Todavía no jugaste ninguna partida</strong>
                <p>¡Animate y empezá tu primera!</p>
            </div>
        {{/partidas}}

    </div>

</main>

{{> footer}}

</body>
</html>