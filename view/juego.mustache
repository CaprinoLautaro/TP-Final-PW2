<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados – Jugando</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./public/css/juegoView.css">
</head>
<body>

{{>header}}

<div class="categoria-banner" style="background-color: {{pregunta.categoria_color}}">
    <span class="categoria-nombre">{{pregunta.categoria_nombre}}</span>
</div>

<main class="juego-main">

    <div class="juego-meta">
        <span class="progreso">
            Pregunta <strong>{{numero_pregunta}}</strong> de <strong>{{total_preguntas}}</strong>
        </span>
        <div class="timer-container">
            <span class="timer-icon">⏱️</span>
            <p class="timer-text">Tiempo restante: <span id="timer" class="timer-count">{{tiempo_restante}}</span>s</p>
        </div>
        <span class="puntaje-actual">
            Puntaje: <strong>{{puntaje_actual}}</strong>
        </span>
    </div>

    <div class="barra-progreso">
        <div
            class="barra-relleno"
            style="width: {{porcentaje_progreso}}%; background-color: {{pregunta.categoria_color}}"
        ></div>
    </div>

    <div class="pregunta-card" style="border-top: 4px solid {{pregunta.categoria_color}}">
        <p class="pregunta-enunciado">
            {{pregunta.enunciado}}
        </p>
        <div class="reportar-wrapper">
            <a href="?controller=partida&method=reportar&pregunta_id={{pregunta.id}}" class="reportar-btn" >
            ⚑ Reportar pregunta
            </a>
        </div>
    </div>

    <form
        class="opciones-form"
        action="?controller=partida&method=responder"
        method="POST"
    >
        <input type="hidden" name="pregunta_id" value="{{pregunta.id}}">

        <div class="opciones-grid">
            {{#opciones}}
            <button
                type="submit"
                name="opcion_id"
                value="{{id}}"
                class="opcion-btn"
            >
                <span class="opcion-letra">{{letra}}</span>
                <span class="opcion-texto">{{texto}}</span>
            </button>
            {{/opciones}}
        </div>
    </form>

</main>

{{>footer}}
<script>
    history.pushState({ enJuego: true }, '');

    window.addEventListener('popstate', function () {
        window.location.href = '?controller=partida&method=abandonar';
    });

    // ── Timer existente (sin cambios) ──
    document.addEventListener("DOMContentLoaded", function () {
        let tiempoRestante = parseInt("{{tiempo_restante}}") || 15;
        const selectorTimer = document.getElementById('timer');
        const formulario = document.querySelector('.opciones-form');

        const cuentaRegresiva = setInterval(() => {
            tiempoRestante--;

            if (selectorTimer) {
                selectorTimer.textContent = tiempoRestante;
            }

            if (tiempoRestante <= 5 && selectorTimer) {
                selectorTimer.style.color = '#E74C3C';
                selectorTimer.style.fontWeight = '800';
            }

            if (tiempoRestante <= 0) {
                clearInterval(cuentaRegresiva);
                tiempoTerminado();
            }
        }, 1000);

        function tiempoTerminado() {
            const inputTiempoAgotado = document.createElement('input');
            inputTiempoAgotado.type = 'hidden';
            inputTiempoAgotado.name = 'tiempo_agotado';
            inputTiempoAgotado.value = '1';
            formulario.appendChild(inputTiempoAgotado);
            formulario.submit();
        }
    });
</script>


</body>
</html>
