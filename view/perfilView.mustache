<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Mi perfil</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/perfilView.css">
</head>

<body>

{{> header}}

<main>
    <form action="?controller=perfil&method=procesarEdicion" method="POST" style="width: 100%;">

        <input
                type="hidden"
                id="latitud"
                name="latitud"
                value="{{latitud}}">

        <input
                type="hidden"
                id="longitud"
                name="longitud"
                value="{{longitud}}">

        <div class="perfil-hero">

            <div class="avatar-circle">
                {{#foto_perfil}}
                    <img src="{{foto_perfil}}" alt="Foto de perfil">
                {{/foto_perfil}}
                {{^foto_perfil}}
                    {{inicial}}
                {{/foto_perfil}}
            </div>

            <div>
                <div class="perfil-nombre">
                    {{#modo_edicion}}
                    <input type="text" name="nombre_completo" value="{{nombre_completo}}" class="input-perfil-header" required>
                    {{/modo_edicion}}
                    {{#modo_lectura}}
                        {{nombre_completo}}
                    {{/modo_lectura}}
                </div>
                    <div class="perfil-username">@{{nombre_usuario}}</div>
            </div>

        </div>

        <div class="perfil-grid">

            <div class="perfil-campo">
                <span class="label">Email</span>
                <span class="valor">{{email}}</span>
            </div>

            <div class="perfil-campo">
                <span class="label">Ciudad</span>
                <span class="valor">
                        {{#modo_edicion}}
                            <input type="text" id="ciudad" name="ciudad" value="{{ciudad}}" class="input-perfil-campo" required>
                        {{/modo_edicion}}
                    {{#modo_lectura}}
                        {{ciudad}}
                    {{/modo_lectura}}
                </span>
            </div>

            <div class="perfil-campo">
                <span class="label">Sexo</span>
                <span class="valor">
                        {{#modo_edicion}}
                            <select name="sexo" class="select-perfil-campo">
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                                <option value="Prefiero no cargarlo">Prefiero no cargarlo</option>
                            </select>
                        {{/modo_edicion}}
                    {{#modo_lectura}}
                        {{sexo}}
                    {{/modo_lectura}}
                    </span>
            </div>
            <div class="perfil-campo">
                <span class="label">Año de nacimiento</span>
                <span class="valor">
                        {{#modo_edicion}}
                            <input type="number" name="anio_nacimiento" value="{{anio_nacimiento}}" class="input-perfil-campo" required>
                        {{/modo_edicion}}
                    {{#modo_lectura}}
                        {{anio_nacimiento}}
                    {{/modo_lectura}}
                    </span>
            </div>
        </div>

        <div class="perfil-mapa-seccion">
            <div class="section-title">Mi ubicación</div>
            <div class="map-container">
            <div id="map" style="width: 100%; height: 300px; border-radius: 8px;"></div>
        </div>

        <p class="perfil-coords">
            📍 {{ciudad}} — {{latitud}}, {{longitud}}
        </p>
        </div>

        <div class="perfil-actions">

            {{#modo_edicion}}
                    <button type="submit" class="btn-main btn-guardar" style="border: none; cursor: pointer;">
                        💾 Guardar cambios
                    </button>
                    <a href="?controller=perfil&method=index" class="btn-main btn-volver">
                        ❌ Cancelar
                    </a>
            {{/modo_edicion}}
            {{#modo_lectura}}
            <a href="?controller=perfil&method=editarPerfil" class="btn-main btn-editar">
                ✏️ Editar perfil
            </a>
            <a href="?controller=home&method=index" class="btn-main btn-volver">
                ← Volver
            </a>
            {{/modo_lectura}}
        </div>
    </form>
</main>

<script>
    function initMap() {
        // Capturamos las coordenadas iniciales que vienen de la BD
        const pos = {
            lat: parseFloat("{{latitud}}") || -34.5975446, // Por si las dudas cae en CABA por defecto
            lng: parseFloat("{{longitud}}") || -58.4085508
        };

        const map = new google.maps.Map(
                document.getElementById("map"),
                {
                    zoom: 14,
                    center: pos
                }
        );

        const esModoEdicion = {{#modo_edicion}}true{{/modo_edicion}}{{^modo_edicion}}false{{/modo_edicion}};
        const marker = new google.maps.Marker({
            position: pos,
            map: map,
            draggable: esModoEdicion
        });

        if (esModoEdicion) {

            map.addListener(marker, 'dragend', function (event) {

                    marker.setPosition(event.latLng);

                    const lat = event.latLng.lat();
                    const lng = event.latLng.lng();

                    document.getElementById('latitud').value = lat;
                    document.getElementById('longitud').value = lng;

                    fetch(
                            `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`
                    )
                            .then(response => response.json())
                            .then(data => {

                                console.log(data);

                                const ciudad =
                                        data.address.city ||
                                        data.address.town ||
                                        data.address.village ||
                                        "";

                                const pais =
                                        data.address.country || "";

                                console.log("País:", pais);
                                console.log("Ciudad:", ciudad);
                                document.getElementById('ciudad').value = ciudad;

                            });
                });

            map.addListener('click', function (event) {

                marker.setPosition(event.latLng);

                const lat = event.latLng.lat();
                const lng = event.latLng.lng();

                document.getElementById('latitud').value = lat;
                document.getElementById('longitud').value = lng;

                fetch(
                        `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`
                )
                        .then(response => response.json())
                        .then(data => {

                            console.log(data);

                            const ciudad =
                                    data.address.city ||
                                    data.address.town ||
                                    data.address.village ||
                                    "";

                            const pais =
                                    data.address.country || "";

                            console.log("País:", pais);
                            console.log("Ciudad:", ciudad);
                            document.getElementById('ciudad').value = ciudad;

                        });
            });
        }
    }
</script>

<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBk9DLeup0-V7pz5-ua52YI8qz_Sk6yC94&callback=initMap" async defer></script>

{{> footer}}

</body>
</html>