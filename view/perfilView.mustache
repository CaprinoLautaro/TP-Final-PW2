<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Mi perfil</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./public/css/perfilView.css">
</head>

<body>

{{> header}}

<main>

    <div class="perfil-hero">

        <div class="avatar-circle">
            {{#foto_perfil}}
                <img src="{{foto_perfil}}" alt="Foto de perfil">
            {{/foto_perfil}}
            {{^foto_perfil}}
                {{inicial}}
            {{/foto_perfil}}
        </div>

        <div>
            <div class="perfil-nombre">{{nombre_completo}}</div>
            <div class="perfil-username">@{{nombre_usuario}}</div>
        </div>

    </div>

    <div class="perfil-grid">

        <div class="perfil-campo">
            <span class="label">Email</span>
            <span class="valor">{{email}}</span>
        </div>

        <div class="perfil-campo">
            <span class="label">Ciudad</span>
            <span class="valor">{{ciudad}}</span>
        </div>

        <div class="perfil-campo">
            <span class="label">Sexo</span>
            <span class="valor">{{sexo}}</span>
        </div>

        <div class="perfil-campo">
            <span class="label">Año de nacimiento</span>
            <span class="valor">{{anio_nacimiento}}</span>
        </div>  
    </div>

    <div class="perfil-mapa-seccion">
        <div class="section-title">Mi ubicación</div>
        <div class="map-container">
        <div id="map" style="width: 100%; height: 300px; border-radius: 8px;"></div>
    </div>

    <p class="perfil-coords">
        📍 {{ciudad}} — {{latitud}}, {{longitud}}
    </p>
    </div>

    <div class="perfil-actions">
        <a href="?controller=home&method=index" class="btn-main btn-editar">
            ✏️ Editar perfil
        </a>
        <a href="?controller=home&method=index" class="btn-main btn-volver">
            ← Volver
        </a>
    </div>

</main>

<script>
    function initMap() {
        const pos = {
            lat: {{latitud}},
            lng: {{longitud}}
        };

        const map = new google.maps.Map(
            document.getElementById("map"),
            {
                zoom: 14,
                center: pos
            }
        );

        new google.maps.Marker({
            position: pos,
            map: map
        });
    }
</script>

<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAcW2OczhYH2aFqMMF2VG-asLJf3HJJzxg&callback=initMap" async defer></script>

{{> footer}}

</body>
</html>