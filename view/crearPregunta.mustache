<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Crear Pregunta</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="./public/css/crearPregunta.css">
</head>

<body>

{{> header}}

<main>

    <div class="form-card">

        <div class="section-title">
            ✏️ Crear nueva pregunta
        </div>

        <form action="?controller=pregunta&method=guardar" method="POST">

            <div class="campo">
                <label for="enunciado">Pregunta</label>

                <textarea
                        id="enunciado"
                        name="enunciado"
                        required>
                </textarea>
            </div>

            <div class="campo">

                <label for="categoria_id">
                    Categoría
                </label>

                <select
                        id="categoria_id"
                        name="categoria_id"
                        required>

                    <option value="">
                        Seleccionar categoría
                    </option>

                    {{#categorias}}
                        <option value="{{id}}">
                            {{nombre}}
                        </option>
                    {{/categorias}}

                </select>

            </div>

            <div class="section-title">
                Respuestas
            </div>

            <div class="opciones-grid">

                <div class="campo">
                    <label for="opcion_a">
                        Opción A
                    </label>

                    <input
                            type="text"
                            id="opcion_a"
                            name="opcion_a"
                            required>
                </div>

                <div class="campo">
                    <label for="opcion_b">
                        Opción B
                    </label>

                    <input
                            type="text"
                            id="opcion_b"
                            name="opcion_b"
                            required>
                </div>

                <div class="campo">
                    <label for="opcion_c">
                        Opción C
                    </label>

                    <input
                            type="text"
                            id="opcion_c"
                            name="opcion_c"
                            required>
                </div>

                <div class="campo">
                    <label for="opcion_d">
                        Opción D
                    </label>

                    <input
                            type="text"
                            id="opcion_d"
                            name="opcion_d"
                            required>
                </div>

            </div>

            <div class="campo">

                <label for="correcta">
                    Respuesta correcta
                </label>

                <select id="correcta" name="correcta" required>

                    <option value="" selected disabled>
                        Seleccionar respuesta correcta
                    </option>

                    <option value="A">
                        A
                    </option>

                    <option value="B">
                        B
                    </option>

                    <option value="C">
                        C
                    </option>

                    <option value="D">
                        D
                    </option>

                </select>

            </div>

            <div class="form-actions">

                <button
                        type="submit"
                        class="btn-main btn-enviar">

                    Guardar pregunta

                </button>

                <a
                        href="?controller=home&method=index"
                        class="btn-main btn-cancelar">

                    Volver

                </a>

            </div>

        </form>

    </div>

</main>

{{> footer}}

</body>
</html>