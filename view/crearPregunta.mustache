<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preguntados - Crear Pregunta</title>

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="./public/css/crearPregunta.css">
</head>

<body>

{{> header}}

<main>

    <div class="welcome-card">
        <h1>
            <span>Contribuir</span>
            Crear nueva pregunta
        </h1>
    </div>

    <div class="section-title">
        Las nuevas preguntas estan sujetas a revisión por los administradores.
    </div>

    <div class="partidas-list">
        <div class="partida-card formulario-card">

            <form action="?controller=pregunta&method=guardar" method="POST" class="formulario-pregunta">

                <div class="form-group-trivia">
                    <label for="enunciado">Pregunta</label>
                    <textarea id="enunciado" name="enunciado" required class="input-trivia text-area-trivia" placeholder="Escribí acá el enunciado de la pregunta..."></textarea>
                </div>

                <div class="form-group-trivia">
                    <label for="categoria_id">Categoría</label>
                    <select id="categoria_id" name="categoria_id" required class="input-trivia select-trivia">
                        <option value="" selected disabled>Seleccionar categoría</option>
                        {{#categorias}}
                            <option value="{{id}}">{{nombre}}</option>
                        {{/categorias}}
                    </select>
                </div>

                <fieldset class="opciones-fieldset">
                    <legend>Respuestas</legend>
                    <p class="ayuda-formulario"><small>* Selecciona el botón redondo de la letra para marcar cuál va a ser la correcta.</small></p>

                    <div class="opcion-input-group">
                        <label class="radio-contenedor">
                            <input type="radio" name="correcta" value="A" required>
                            <span class="radio-custom">A</span>
                        </label>
                        <input type="text" id="opcion_a" name="opcion_a" required class="input-trivia text-input-trivia" placeholder="Texto de la opción A">
                    </div>

                    <div class="opcion-input-group">
                        <label class="radio-contenedor">
                            <input type="radio" name="correcta" value="B" required>
                            <span class="radio-custom">B</span>
                        </label>
                        <input type="text" id="opcion_b" name="opcion_b" required class="input-trivia text-input-trivia" placeholder="Texto de la opción B">
                    </div>

                    <div class="opcion-input-group">
                        <label class="radio-contenedor">
                            <input type="radio" name="correcta" value="C" required>
                            <span class="radio-custom">C</span>
                        </label>
                        <input type="text" id="opcion_c" name="opcion_c" required class="input-trivia text-input-trivia" placeholder="Texto de la opción C">
                    </div>

                    <div class="opcion-input-group">
                        <label class="radio-contenedor">
                            <input type="radio" name="correcta" value="D" required>
                            <span class="radio-custom">D</span>
                        </label>
                        <input type="text" id="opcion_d" name="opcion_d" required class="input-trivia text-input-trivia" placeholder="Texto de la opción D">
                    </div>
                </fieldset>

                <div class="form-box-acciones">
                    <button type="submit" class="btn-aprobar">💾 Guardar pregunta</button>
                    <a href="?controller=home&method=index" class="btn-rechazar">❌ Volver</a>
                </div>

            </form>

        </div>
    </div>

</main>


{{> footer}}

</body>
</html>